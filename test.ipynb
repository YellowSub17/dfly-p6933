    "import h5py\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "with h5py.File('./det/mask_hvoff_20250311.h5', 'r') as f:\n",
    "    mask = f['/entry_1/data_1/mask'][:]\n",
    "\n",
    "x =np.random.random( mask.shape)\n",
    "y = x*np.abs(mask-1)\n",
    "plt.imshow(y[7])"
   ]
